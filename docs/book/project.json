{
  "name": "docs-book",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "docs/book",
  "targets": {
    "dev": {
      "cache": true,
      "inputs": ["{workspaceRoot}/docs/book/**/*"],
      "outputs": ["{workspaceRoot}/dist/docs/book"],
      "dependsOn": ["clean", "^build"],
      "command": "mdbook serve --open",
      "options": {
        "cwd": "{projectRoot}",
        "color": true
      }
    },
    "build": {
      "cache": true,
      "inputs": ["{workspaceRoot}/docs/book/**/*"],
      "outputs": ["{workspaceRoot}/dist/docs/book"],
      "dependsOn": ["clean", "^build"],
      "command": "mdbook build",
      "options": {
        "cwd": "{projectRoot}",
        "color": true
      }
    },
    "lint": {
      "cache": true,
      "inputs": ["{workspaceRoot}/docs/book/**/*"],
      "outputs": ["{workspaceRoot}/dist/docs/book"],
      "dependsOn": ["clean", "^build"],
      "command": "mdbook-linkcheck --standalone",
      "options": {
        "cwd": "{projectRoot}",
        "color": true
      }
    }
  },
  "tags": []
}
