{
  "name": "nodejs-sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "bindings/nodejs-sdk/src",
  "targets": {
    "version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "napi version",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck-base": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm copyfiles src/bindings.cjs src/bindings.d.cts out-tsc",
        "cwd": "{projectRoot}"
      }
    },
    "build-x86_64-apple-darwin": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "x86_64-apple-darwin"
        }
      }
    },
    "build-aarch64-apple-darwin": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "aarch64-apple-darwin"
        }
      }
    },
    "build-x86_64-unknown-linux-gnu": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "x86_64-unknown-linux-gnu"
        }
      }
    },
    "build-x86_64-unknown-linux-musl": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "x86_64-unknown-linux-musl",
          "crossCompile": "true"
        }
      }
    },
    "build-aarch64-unknown-linux-gnu": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "aarch64-unknown-linux-gnu",
          "crossCompile": "true"
        }
      }
    },
    "build-aarch64-unknown-linux-musl": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "aarch64-unknown-linux-musl",
          "crossCompile": "true"
        }
      }
    },
    "build-armv7-unknown-linux-gnueabihf": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "armv7-unknown-linux-gnueabihf",
          "crossCompile": "true"
        }
      }
    },
    "build-aarch64-linux-android": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "aarch64-linux-android"
        }
      }
    },
    "build-armv7-linux-androideabi": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "armv7-linux-androideabi"
        }
      }
    },
    "build-wasm32-wasip1-threads": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "wasm32-wasip1-threads"
        }
      }
    },
    "build-aarch64-pc-windows-msvc": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "aarch64-pc-windows-msvc",
          "crossCompile": "true"
        }
      }
    },
    "build-x86_64-pc-windows-msvc": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "x86_64-pc-windows-msvc",
          "crossCompile": "true"
        }
      }
    },
    "build-i686-pc-windows-msvc": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "i686-pc-windows-msvc",
          "crossCompile": "true"
        }
      }
    },
    "build-x86_64-unknown-freebsd": {
      "executor": "@powerlines/nx:build",
      "options": {
        "additionalArgs": {
          "target": "x86_64-unknown-freebsd",
          "crossCompile": "true"
        }
      }
    },
    "artifacts": {
      "executor": "nx:run-commands",
      "options": {
        "command": "napi artifacts --build-output-dir artifacts",
        "cwd": "{projectRoot}"
      }
    },
    "napi-prepublish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "napi prepublish -t npm",
        "cwd": "{projectRoot}"
      }
    },
    "nx-release-publish": {
      "executor": "@storm-software/workspace-tools:npm-publish",
      "dependsOn": ["napi-prepublish"]
    }
  },
  "tags": ["platform:node"]
}
