{
  "$schema": "https://cdn.jsdelivr.net/npm/nx/schemas/nx-schema.json",
  "extends": "@storm-software/workspace-tools/config/recommended.json",
  "release": {
    "groups": {
      "bindings": {
        "projects": ["bindings/*"],
        "projectsRelationship": "independent"
      }
    }
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "compiler": "tsgo",
        "typecheck": true,
        "build": false,
        "verboseOutput": false
      }
    },
    "@storm-software/workspace-tools/plugins/typescript",
    "@storm-software/workspace-tools/plugins/typescript/untyped",
    "@storm-software/workspace-tools/plugins/typescript/tsdown",
    "@storm-software/workspace-tools/plugins/rust",
    "@powerlines/nx/plugin"
  ],
  "sync": {
    "applyChanges": true,
    "globalGenerators": ["@nx/js:typescript-sync"]
  },
  "analytics": false
}
